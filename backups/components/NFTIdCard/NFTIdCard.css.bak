/* NFT ID Card Styles */

/* Card base */
.card-base {
  position: relative;
  width: 100%;
  height: 100%;
  border-radius: 0.75rem;
  background: #001a15;
  overflow: hidden;
}

/* Holographic border with NOVA Bulgaria colors - static gradient */
.pokemon-holo-border {
  position: absolute;
  inset: 0;
  border-radius: inherit;
  background: linear-gradient(
    125deg,
    #00966E 0%,    /* Green */
    #33cc33 10%,   /* Light green */
    #ffff00 20%,   /* Yellow */
    #ff9900 30%,   /* Orange */
    #00966E 40%,   /* Green */
    #33cc33 50%,   /* Light green */
    #ffff00 60%,   /* Yellow */
    #ff9900 70%,   /* Orange */
    #00966E 80%,   /* Green */
    #33cc33 90%,   /* Light green */
    #ffff00 100%   /* Yellow */
  );
  background-size: 400% 400%;
  /* Fixed position instead of animation */
  background-position: 0% 50%;
  animation: none;
  z-index: 2;
}

/* Inner card cutout */
.card-inner {
  position: absolute;
  inset: 10px;
  border-radius: calc(0.75rem - 5px);
  background: #001a15;
  z-index: 3;
}

/* X pattern texture overlay with distortion - only for border */
.x-pattern {
  position: absolute;
  inset: 0;
  background-image: 
    linear-gradient(45deg, transparent 45%, rgba(255, 255, 255, 0.15) 45%, rgba(255, 255, 255, 0.15) 55%, transparent 55%),
    linear-gradient(-45deg, transparent 45%, rgba(255, 255, 255, 0.15) 45%, rgba(255, 255, 255, 0.15) 55%, transparent 55%);
  background-size: 20px 20px;
  opacity: 0.7;
  z-index: 4;
  /* Mask to only show on border */
  -webkit-mask: 
    linear-gradient(#fff 0 0) content-box, 
    linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask: 
    linear-gradient(#fff 0 0) content-box, 
    linear-gradient(#fff 0 0);
  mask-composite: exclude;
  padding: 10px;
  /* Remove animation, keep static appearance */
  animation: none;
  transform: scale(1);
}

/* Secondary distortion layer for more complex effect */
.distortion-layer {
  position: absolute;
  inset: 0;
  background-image: 
    radial-gradient(ellipse at 30% 40%, rgba(255, 255, 255, 0.1) 0%, transparent 70%),
    radial-gradient(circle at 70% 60%, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
  mix-blend-mode: overlay;
  opacity: 0.5;
  z-index: 4;
  /* Mask to only show on border */
  -webkit-mask: 
    linear-gradient(#fff 0 0) content-box, 
    linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask: 
    linear-gradient(#fff 0 0) content-box, 
    linear-gradient(#fff 0 0);
  mask-composite: exclude;
  padding: 10px;
  /* Remove animation */
  animation: none;
  background-position: 0% 0%;
}

/* Sparkle effect - only for border */
.sparkles {
  position: absolute;
  inset: 0;
  background-image: 
    radial-gradient(circle at 20% 30%, rgba(255, 255, 255, 0.8) 0%, rgba(255, 255, 255, 0) 3%),
    radial-gradient(circle at 80% 20%, rgba(255, 255, 255, 0.8) 0%, rgba(255, 255, 255, 0) 3%),
    radial-gradient(circle at 40% 70%, rgba(255, 255, 255, 0.8) 0%, rgba(255, 255, 255, 0) 3%),
    radial-gradient(circle at 70% 50%, rgba(255, 255, 255, 0.8) 0%, rgba(255, 255, 255, 0) 3%),
    radial-gradient(circle at 90% 90%, rgba(255, 255, 255, 0.8) 0%, rgba(255, 255, 255, 0) 3%);
  mix-blend-mode: overlay;
  /* Remove animation */
  animation: none;
  opacity: 0.4;
  z-index: 5;
  /* Mask to only show on border */
  -webkit-mask: 
    linear-gradient(#fff 0 0) content-box, 
    linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask: 
    linear-gradient(#fff 0 0) content-box, 
    linear-gradient(#fff 0 0);
  mask-composite: exclude;
  padding: 10px;
}

/* Card content */
.card-content {
  position: relative;
  height: 100%;
  width: 100%;
  z-index: 6;
}

/* Animations - kept for reference but not used */
@keyframes rainbow-shift {
  0% { background-position: 0% 50%; }
  25% { background-position: 50% 25%; }
  50% { background-position: 100% 50%; }
  75% { background-position: 50% 75%; }
  100% { background-position: 0% 50%; }
}

@keyframes texture-distort {
  0% { 
    transform: scale(1) skew(0deg, 0deg); 
    background-size: 20px 20px;
  }
  25% { 
    transform: scale(1.05) skew(1deg, 0.5deg); 
    background-size: 22px 19px;
  }
  50% { 
    transform: scale(0.98) skew(-0.5deg, 1deg); 
    background-size: 19px 21px;
  }
  75% { 
    transform: scale(1.02) skew(0.8deg, -0.3deg); 
    background-size: 21px 20px;
  }
  100% { 
    transform: scale(1) skew(0deg, 0deg); 
    background-size: 20px 20px;
  }
}

@keyframes distortion-shift {
  0% { 
    opacity: 0.4;
    background-position: 0% 0%;
  }
  33% { 
    opacity: 0.6;
    background-position: 10% 30%;
  }
  66% { 
    opacity: 0.5;
    background-position: -5% 10%;
  }
  100% { 
    opacity: 0.4;
    background-position: 0% 0%;
  }
}

@keyframes sparkle {
  0% { opacity: 0.2; }
  25% { opacity: 0.4; }
  50% { opacity: 0.6; }
  75% { opacity: 0.3; }
  100% { opacity: 0.2; }
}

/* QR code styling */
.qr-code-container {
  display: flex;
  justify-content: center;
  align-items: center;
  width: 100%;
  height: 100%;
  background: white;
  border-radius: 0.5rem;
  overflow: hidden;
}

/* Glass morphism for card elements */
.glass {
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
}

/* Responsive scaling for mobile devices */
